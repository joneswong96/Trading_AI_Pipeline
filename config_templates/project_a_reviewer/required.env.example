# Required non-secret paths/identity. The numeric Telegram ID is private runtime
# configuration and must not be committed with a real value.
PROJECT_A_REVIEWER_WORKSPACE=
PROJECT_A_REVIEWER_AGENT_DIR=
PROJECT_A_REVIEWER_MODEL=
PROJECT_A_TELEGRAM_USER_ID=

# Secrets: set in the protected OpenClaw service environment or approved SecretRef
# provider only. Never write real values into this file.
PROJECT_A_OPENCLAW_GATEWAY_TOKEN=
PROJECT_A_TELEGRAM_BOT_TOKEN=
