# .env.example — 複製做 .env 再填值。⚠️ .env 有真 secret，永不 commit（見 .gitignore）。
# 呢個 template 只係 key 名 + 非-secret 預設；secret 一律留空，唔好喺度填真值。

# ── Anthropic（API 路 analyze/claude_client.py 用；手動 /analyze 唔需要 key）──────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Telegram push（notify-only）──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notion call-log ─────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_CALLLOG_DB_ID=

# ── Capture（route 1b CDP 9222）+ Playwright profile ─────────────────────────
TV_CDP_PORT=9222
PLAYWRIGHT_PROFILE_DIR=storage/pw_profile
